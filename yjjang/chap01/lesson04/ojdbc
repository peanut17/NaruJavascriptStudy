Plain text
A 서버 A_TABLE → B 서버 B_TABLE
B 서버 B_TABLE → A 서버 A_TABLE
1. Maven pom.xml
XML
@Configuration
@RequiredArgsConstructor
public class AToBBatchConfig {

    private final JobRepository jobRepository;

    @Qualifier("oracleADataSource")
    private final DataSource oracleADataSource;

    @Qualifier("oracleBDataSource")
    private final DataSource oracleBDataSource;

    @Qualifier("oracleBTransactionManager")
    private final PlatformTransactionManager oracleBTransactionManager;

    @Bean
    public JdbcCursorItemReader<EtlDataDto> aToBReader() {
        return new JdbcCursorItemReaderBuilder<EtlDataDto>()
                .name("aToBReader")
                .dataSource(oracleADataSource)
                .sql("""
                    SELECT ID, NAME, CREATED_AT, UPDATED_AT
                    FROM A_TABLE
                    WHERE UPDATED_AT >= SYSDATE - (5 / 1440)
                    """)
                .rowMapper((rs, rowNum) -> {
                    EtlDataDto dto = new EtlDataDto();
                    dto.setId(rs.getLong("ID"));
                    dto.setName(rs.getString("NAME"));
                    dto.setCreatedAt(rs.getTimestamp("CREATED_AT").toLocalDateTime());
                    dto.setUpdatedAt(rs.getTimestamp("UPDATED_AT").toLocalDateTime());
                    return dto;
                })
                .build();
    }

    @Bean
    public JdbcBatchItemWriter<EtlDataDto> aToBWriter() {
        return new JdbcBatchItemWriterBuilder<EtlDataDto>()
                .dataSource(oracleBDataSource)
                .sql("""
                    MERGE INTO B_TABLE T
                    USING (
                        SELECT :id ID,
                               :name NAME,
                               :createdAt CREATED_AT,
                               :updatedAt UPDATED_AT
                        FROM DUAL
                    ) S
                    ON (T.ID = S.ID)
                    WHEN MATCHED THEN
                        UPDATE SET
                            T.NAME = S.NAME,
                            T.UPDATED_AT = S.UPDATED_AT
                    WHEN NOT MATCHED THEN
                        INSERT (
                            ID, NAME, CREATED_AT, UPDATED_AT
                        )
                        VALUES (
                            S.ID, S.NAME, S.CREATED_AT, S.UPDATED_AT
                        )
                    """)
                .beanMapped()
                .build();
    }

    @Bean
    public Step aToBStep() {
        return new StepBuilder("aToBStep", jobRepository)
                .<EtlDataDto, EtlDataDto>chunk(1000, oracleBTransactionManager)
                .reader(aToBReader())
                .writer(aToBWriter())
                .build();
    }

    @Bean
    public Job aToBJob() {
        return new JobBuilder("aToBJob", jobRepository)
                .start(aToBStep())
                .build();
    }
}
